{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        "outDir": "./dist",
        "noEmitOnError": true,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "lib": [
            "ESNext"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        "types": [
            "./worker-configuration.d.ts",
            "node"
        ]
    }
}